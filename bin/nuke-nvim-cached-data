#!/usr/bin/env bash

RED="\033[31m"
NO_COLOR="\033[0m"

if [ "$(pgrep nvim -u "${USER}" -c)" -gt 0 ]; then
    echo -e "${RED}Error: nvim still running for user ${USER}${NO_COLOR}"
    pgrep nvim -u "${USER}" -a
    exit 1
fi

echo -e "${RED}========================================================${NO_COLOR}"
echo -e "${RED}=== CAUTION: The following files will be removed !!! ===${NO_COLOR}"
echo -e "${RED}========================================================${NO_COLOR}"

# Remove plugins and lazy.nvim state
ls -al ~/.local/share/nvim

# Remove undo history, shada (registers/marks), and swap files
ls -al ~/.local/state/nvim

# Remove cached bytecode and treesitter parsers
ls -al ~/.cache/nvim

echo -e "${RED}========================================================${NO_COLOR}"
echo -e "${RED}=== CAUTION: The following files will be removed !!! ===${NO_COLOR}"
echo -e "${RED}========================================================${NO_COLOR}"

read -p "Are you sure? " -n 1 -r
echo ""

if [[ $REPLY =~ ^[Yy]$ ]]; then
    set -x
    # Remove plugins and lazy.nvim state
    rm -rf ~/.local/share/nvim

    # Remove undo history, shada (registers/marks), and swap files
    rm -rf ~/.local/state/nvim

    # Remove cached bytecode and treesitter parsers
    rm -rf ~/.cache/nvim
fi
