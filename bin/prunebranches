#!/usr/bin/env bash

BLUE='\033[0;34m'
NOFORMAT='\033[0m'

msg() {
    echo >&2 -e "${1-}:: ${2-}${NOFORMAT}"
}

msg "${BLUE}" "Pruning unreachable objects..."
git fetch --prune
msg "${BLUE}" "Pruning done.\n"


BRANCHES_TO_PRUNE=$(git branch -vv | grep ': gone]' | grep -v -E '\*' | awk '{print $1;}')

if [ -z "$BRANCHES_TO_PRUNE" ]; then
    msg "${BLUE}" "No branches to remove"
    exit 0
fi

msg "${BLUE}" "Branches to remove"
echo "$BRANCHES_TO_PRUNE"
read -p "Are you sure that you want to delete these branches? " -n 1 -r
if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    msg "${BLUE}" "Stopped.\n"
    exit 1
fi

echo "$BRANCHES_TO_PRUNE" | xargs -r git branch -D
msg "${BLUE}" "Done"
